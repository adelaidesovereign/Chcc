{
  "name": "chcc-clubhouse",
  "version": "0.1.0",
  "private": true,
  "description": "Chapel Hill Country Club — member experience platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\" --ignore-path .gitignore",

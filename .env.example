# ===================================================================
# Chapel Hill Country Club — Environment Configuration
# Copy this file to .env.local for local development.
# ===================================================================

# ----- App -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----- Adapter mode -----
# "mock"  — use local sample data (demo, development)
# "live"  — call ClubEssential API (production, post-signature)
NEXT_PUBLIC_ADAPTER_MODE="mock"

# ----- Active club -----
# The slug of the club configuration to load. Today: "chcc".
NEXT_PUBLIC_ACTIVE_CLUB="chcc"

# ----- Supabase -----
# Create a project at https://supabase.com, then copy these values
# from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ----- Database (Prisma → Supabase Postgres) -----
# Found in Supabase → Project Settings → Database → Connection string.
# Use the "Connection pooling" string for DATABASE_URL and the
# "Direct connection" string for DIRECT_URL.
DATABASE_URL=""
DIRECT_URL=""

# ----- ClubEssential (Phase 5) -----
# Leave blank until live integration. LiveAdapter throws clearly
# without these.
CLUBESSENTIAL_API_BASE=""
CLUBESSENTIAL_API_KEY=""
CLUBESSENTIAL_CLUB_ID=""

# ----- Email (Resend) -----
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Chapel Hill Country Club <noreply@chapelhillcc.com>"

# ----- Anthropic (Phase 3 — AI concierge) -----
ANTHROPIC_API_KEY=""

# ----- Observability -----
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
